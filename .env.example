AI_PROVIDER=local
# 如果没有大模型可以使用本地规则，有模型请改为 openai-compatible

AI_DOTENV_OVERRIDE=false

# OpenAI-compatible provider. Copy this file to .env and fill values locally.
# Keep .env private; never commit it to a public repository.
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_API_KEY=replace-with-your-local-key

# Generation controls
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=3000
AI_MAX_RETRIES=2
AI_CONSISTENCY_RETRIES=1


# Chunking controls
# auto: summarize chunks only for long chapters; off: skip chunk summaries for speed; always: always summarize chunks.
AI_CHUNK_SUMMARY_MODE=off
AI_CHUNK_SIZE=2600
AI_CHUNK_OVERLAP=180

# Thinking controls for compatible providers.
# This is provider-dependent. The app also injects /no_think into prompts when enabled.
AI_NO_THINK=true
